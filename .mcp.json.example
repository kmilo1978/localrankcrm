{
  "//": "MCP scoped al proyecto. Copia las entradas que necesites a .mcp.json. Los ${VAR} se resuelven desde tu entorno / .env — NUNCA pongas tokens en claro aquí.",

  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": ["-y", "supabase-mcp-server@latest"],
      "env": {
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_KEY": "${SUPABASE_SERVICE_ROLE_KEY}"
      }
    },

    "hermes-agent": {
      "command": "npx",
      "args": ["-y", "hermes-mcp@latest"],
      "env": {
        "HERMES_API_URL": "http://localhost:3001",
        "HERMES_API_KEY": "${HERMES_API_KEY}"
      },
      "//": "Hermes Agent (NousResearch) — Agente IA multicanal. Instalar: pip install hermes-agent. Conecta Telegram, Discord, Slack, Signal, Matrix. Docs: https://hermes-agent.nousresearch.com"
    },

    "openclaw": {
      "command": "npx",
      "args": ["-y", "openclaw-mcp-server@latest"],
      "env": {
        "OPENCLAW_URL": "http://localhost:4000",
        "OPENCLAW_TOKEN": "${OPENCLAW_TOKEN}"
      },
      "//": "OpenClaw — Gateway de agentes IA self-hosted. Conecta Discord, WhatsApp, Telegram, Slack, Teams, iMessage. Docs: https://docs.openclaw.ai. Install: curl -fsSL https://openclaw.ai/install.sh | sh"
    },

    "obsidian": {
      "command": "npx",
      "args": ["-y", "obsidian-mcp-server@latest"],
      "env": {
        "OBSIDIAN_VAULT_PATH": "${OBSIDIAN_VAULT_PATH}",
        "OBSIDIAN_API_PORT": "27123"
      },
      "//": "Obsidian — Super cerebro. Conecta tu vault de notas/knowledge base con el CRM. Requiere plugin 'Local REST API' en Obsidian. El agente IA puede buscar, leer y crear notas. Docs: https://github.com/MarkusPfworlds/obsidian-mcp"
    },

    "composio": {
      "command": "npx",
      "args": ["-y", "composio-mcp-server@latest"],
      "env": {
        "COMPOSIO_API_KEY": "${COMPOSIO_API_KEY}"
      },
      "//": "Composio.dev — 250+ integraciones con una sola API key. Gmail, Calendar, Sheets, LinkedIn, HubSpot, Notion. Docs: https://docs.composio.dev"
    },

    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },

    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "//": "Navegador automatizado para scraping y testing"
    }
  }
}
