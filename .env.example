# ============================================================
# Vocero CRM — variables de entorno
# Copia este archivo a `.env` y reemplaza cada REEMPLAZA_...
# En producción estas variables van en tu plataforma de hosting
# (Coolify / docker compose), no solo en el archivo.
# ============================================================

# --- Aplicación ---------------------------------------------
# URL pública de la instancia (con https en producción).
# De ella se construye la URL del webhook de WhatsApp.
APP_BASE_URL=REEMPLAZA_https://crm.tudominio.com

# Solo Ruta B (docker compose): dominio para el HTTPS automático de Caddy.
DOMAIN=REEMPLAZA_crm.tudominio.com

# --- Base de datos ------------------------------------------
# Ruta B usa el servicio interno `postgres` del compose.
# Genera la contraseña con:  openssl rand -hex 24
POSTGRES_PASSWORD=REEMPLAZA_password_de_postgres
DATABASE_URL=postgresql://postgres:REEMPLAZA_password_de_postgres@postgres:5432/vocero

# --- Secretos de la aplicación ------------------------------
# Firma de sesiones. Genera con:  openssl rand -base64 32
BETTER_AUTH_SECRET=REEMPLAZA_secreto_de_sesiones

# Cifrado en reposo del token de WhatsApp (AES-256-GCM).
# DEBE ser exactamente 32 bytes en base64 (44 caracteres).
# Genera con:  openssl rand -base64 32
ENCRYPTION_KEY=REEMPLAZA_clave_de_cifrado_base64

# --- WhatsApp (webhook) -------------------------------------
# Token de verificación del webhook. Es también el segmento secreto
# de la URL del webhook: /api/webhooks/wa/<este_valor>
# Genera con:  openssl rand -hex 32
META_WEBHOOK_VERIFY_TOKEN=REEMPLAZA_token_de_verificacion

# OPCIONAL (recomendado en modo directo): App Secret de tu app de Meta
# para validar la firma de cada webhook (x-hub-signature-256).
# Se obtiene en developers.facebook.com → tu app → Configuración → Básica.
# En modo agencia normalmente se deja vacío (la URL secreta protege el webhook).
# META_APP_SECRET=

# Versión de la Graph API (déjala así salvo que sepas por qué cambiarla).
META_GRAPH_API_VERSION=v25.0

# --- Inteligencia artificial (opcional) ---------------------
# Sin token, el CRM funciona completo excepto Agente y Laboratorio.
# Crea tu key en https://openrouter.ai → Keys (o usa cualquier proveedor
# compatible con la API de OpenRouter cambiando OPENROUTER_BASE_URL).
# OPENROUTER_API_TOKEN=
# OPENROUTER_BASE_URL=https://openrouter.ai/api
# Modelo principal del agente (ej.: anthropic/claude-sonnet-4.5)
# OPENROUTER_MODEL=
# Modelo del juez del Laboratorio (si se omite, usa el principal)
# OPENROUTER_JUDGE_MODEL=

# --- Operación (opcional) -----------------------------------
# Reabrir el registro público después de la primera organización.
# ALLOW_SIGNUP=true

# Milisegundos de agrupación de mensajes antes del turno del agente (default 6000).
# AGENT_COALESCE_MS=6000
